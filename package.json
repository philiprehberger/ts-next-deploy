{
  "name": "@philiprehberger/next-deploy",
  "version": "0.1.0",
  "description": "Release-based SSH deployment for Next.js apps with symlinks, dependency caching, and PM2 management",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "next-deploy": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": ["next.js", "deploy", "ssh", "pm2", "release", "symlink", "deployment"],
  "author": "Philip Rehberger",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.0",
    "node-ssh": "^13.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
